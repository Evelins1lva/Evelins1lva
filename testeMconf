        "import zipfile\n",
        "import os\n",
        "\n",
        "# DECISÃO TÉCNICA: Utilização da biblioteca zipfile para extração programática.\n",
        "# Motivo: Garante que o pipeline de dados seja replicável em qualquer ambiente\n",
        "# sem depender de intervenção manual para descompactar arquivos.\n",
        "with zipfile.ZipFile('archive.zip', 'r') as zip_ref:\n",
        "    # Extração total no diretório atual para facilitar o acesso via Pandas nas etapas\n",
        "    zip_ref.extractall('.')\n",
