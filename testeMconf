        "import duckdb\n",
        "import pandas as pd\n",
        "\n",
        "# 1. Preparação robusta do df_ibge\n",
        "col_municipio = 'municipio' if 'municipio' in df_ibge.columns else 'Município'\n",
        "\n",
        "# Extração da UF tratando o formato \"Nome da Cidade - UF\" ou \"Nome da Cidade (UF)\"\n",
        "df_ibge['uf'] = df_ibge[col_municipio].str.split(' - ').str[-1].str.extract(r'([A-Z]{2})')\n",
        "\n",
        "# Garantir que a população seja numérica (remover pontos de milhar se existirem)\n",
        "if df_ibge['populacao'].dtype == 'O':\n",
        "    df_ibge['populacao'] = df_ibge['populacao'].astype(str).str.replace('.', '', regex=False)\n",
        "df_ibge['populacao'] = pd.to_numeric(df_ibge['populacao'], errors='coerce')\n",
        "\n",
        "# 2. Consulta SQL com Chave Composta (Cidade + UF)\n",
        "query_final = \"\"\"\n",
        "SELECT\n",
        "    c.cidade_limpa AS cidade,\n",
        "    c.customer_state AS uf,\n",
        "    MAX(i.populacao) AS populacao_total,\n",
        "    COUNT(DISTINCT c.customer_unique_id) AS total_clientes_unicos\n",
        "FROM df_clientes c\n",
        "LEFT JOIN df_ibge i\n",
        "    ON c.cidade_limpa = i.cidade_limpa\n",
        "    AND c.customer_state = i.uf\n",
        "GROUP BY 1, 2\n",
        "\"\"\"\n",
        "df_unificado = duckdb.sql(query_final).df()\n",
        "\n",
        "# 3. Cálculo da Métrica de Penetração (Clientes por 100k Habitantes)\n",
        "df_unificado['penetracao_100k'] = (df_unificado['total_clientes_unicos'] / df_unificado['populacao_total']) * 100000\n",
        "\n",
        "# 4. Identificação de Oportunidades (Cidades > 200k Hab com menor penetração)\n",
        "df_oportunidades = df_unificado[df_unificado['populacao_total'] > 200000].sort_values(by='penetracao_100k', ascending=True)\n",
        "\n",
        "# 5. Relatório de Integridade Final\n",
        "total_clientes_base = df_clientes['customer_unique_id'].nunique()\n",
        "clientes_mapeados = df_unificado[df_unificado['populacao_total'].notna()]['total_clientes_unicos'].sum()\n",
        "taxa_perda = ((total_clientes_base - clientes_mapeados) / total_clientes_base) * 100\n",
        "\n",
        "print(f\"=== RELATÓRIO DE INTEGRIDADE FINAL ===\")\n",
        "print(f\"Volume total de clientes únicos: {total_clientes_base}\")\n",
        "print(f\"Volume de clientes mapeados com sucesso: {clientes_mapeados}\")\n",
        "print(f\"Taxa de Perda Final: {taxa_perda:.2f}%\")\n",
        "\n",
        "print(\"\\n=== TOP 10 CIDADES OPORTUNIDADE (Alta População / Baixa Penetração) ===\")\n",
        "display(df_oportunidades[['cidade', 'uf', 'populacao_total', 'penetracao_100k']].head(10))"
