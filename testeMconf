        "import pandas as pd\n",
        "import duckdb\n",
        "import unicodedata\n",
        "import zipfile\n",
        "import os\n",
        "import re # Import the regular expression module\n",
        "\n",
        "# --- 1. GESTÃO DE ARQUIVOS E EXTRAÇÃO ---\n",
        "# DECISÃO TÉCNICA: Extração programática utilizando 'zipfile'.\n",
        "# REFLEXÃO: Esta abordagem automatiza o setup do ambiente, garantindo que o pipeline funcione independentemente do upload manual.\n",
        "# LIMITAÇÃO: O método 'extractall' extrai todos os ficheiros em disco; em cenários de Big Data, seria preferível o streaming.\n",
        "\n",
        "# Adicionando um passo para baixar 'archive.zip' se não existir\n",
        "archive_path = 'archive.zip'\n",
        "if not os.path.exists(archive_path):\n",
        "    print(f\"'{archive_path}' not found. Downloading a common Olist dataset.\")\n",
        "    # URL de um dataset Olist público (este é um exemplo, pode precisar ser ajustado)\n",
        "    # Nota: Este dataset é o 'olist_ecommerce_public_dataset.zip' renomeado para 'archive.zip'\n",
        "    download_url = 'https://raw.githubusercontent.com/fernandodev/bootcamp_fullstack_data_science/main/datasets/olist_ecommerce_public_dataset.zip'\n",
        "    try:\n",
        "        import requests\n",
        "        r = requests.get(download_url, stream=True)\n",
        "        if r.status_code == 200:\n",
        "            with open(archive_path, 'wb') as f:\n",
        "                for chunk in r.iter_content(chunk_size=8192):\n",
        "                    f.write(chunk)\n",
        "            print(f\"'{archive_path}' downloaded successfully.\")\n",
        "        else:\n",
        "            print(f\"Failed to download from {download_url}. Status code: {r.status_code}\")\n",
        "            print(\"Please ensure 'archive.zip' is uploaded or the download URL is correct.\")\n",
        "    except Exception as e:\n",
        "        print(f\"Error downloading file: {e}\")\n",
        "        print(\"Please ensure 'archive.zip' is uploaded or the download URL is correct.\")\n",
        "\n",
        "\n",
        "with zipfile.ZipFile(archive_path, 'r') as zip_ref:\n",
        "    zip_ref.extractall('.')\n",
        "\n",
        "# --- 2. CARREGAMENTO E LEITURA ---\n",
        "# DECISÃO TÉCNICA: Leitura via Pandas para manipulação inicial e higienização.\n",
        "df_clientes = pd.read_csv('olist_customers_dataset.csv')\n",
        "df_orders = pd.read_csv('olist_orders_dataset.csv')\n",
        "\n",
        "#PADRONIZAÇÃO DE CHAVES E TRATAMENTO DE ERROS ---\n",
        "def limpar_texto(txt):\n",
        "    if txt is None or pd.isna(txt):\n",
        "        return None\n",
        "    # Converte caracteres especiais para ASCII (remover acentos)\n",
        "    txt = unicodedata.normalize('NFKD', str(txt)).encode('ascii', 'ignore').decode('utf-8')\n",
        "    return txt.lower().strip()\n",
        "\n",
        "# Aplicação da lógica de limpeza no Olist\n",
        "df_clientes['cidade_limpa'] = df_clientes['customer_city'].apply(limpar_texto)\n",
        "\n",
        "# Carregamento do df_ibge (existing code)\n",
        "print(\"Acessando dados do IBGE (Censo 2022)...\")\n",
        "url_ibge = \"https://apisidra.ibge.gov.br/values/t/4709/n6/all/v/93/p/2022\"\n",
        "r = requests.get(url_ibge)\n",
        "df_ibge = pd.DataFrame(r.json()[1:])\n",
        "df_ibge = df_ibge[['MC', 'D1N', 'V']]\n",
        "df_ibge.columns = ['cod_mun', 'municipio', 'populacao']\n",
        "df_ibge['populacao'] = pd.to_numeric(df_ibge['populacao'], errors='coerce')\n",
        "\n",
        "# NEW: Extract UF from 'municipio' column for df_ibge\n",
        "def extract_uf_from_municipio(municipio_str):\n",
        "    if pd.isna(municipio_str):\n",
        "        return None\n",
        "    # Try to extract from ' - UF' pattern\n",
        "    match_dash = re.search(r' - ([A-Z]{2})$', municipio_str)\n",
        "    if match_dash:\n",
        "        return match_dash.group(1)\n",
        "    # Try to extract from '(UF)' pattern (e.g., 'São Paulo (SP)')\n",
        "    match_paren = re.search(r'\\(([A-Z]{2})\\)$', municipio_str)\n",
        "    if match_paren:\n",
        "        return match_paren.group(1)\n",
        "    return None\n",
        "\n",
        "df_ibge['uf'] = df_ibge['municipio'].apply(extract_uf_from_municipio)\n",
        "\n",
        "# DECISÃO TÉCNICA: Tratamento multicamadas para a base do IBGE.\n",
        "# REFLEXÃO: Identifiquei que a base do IBGE possuía dois padrões impeditivos: \"Nome (UF)\" e \"Nome - UF\".\n",
        "# Sem a remoção do sufixo \" - uf\", o match com a base Olist resulta em 0%, gerando valores <NA>.\n",
        "df_ibge['cidade_limpa'] = df_ibge['municipio'].str.split(r' \\(').str[0] # Remove o \"(UF)\"\n",
        "df_ibge['cidade_limpa'] = df_ibge['cidade_limpa'].str.split(' - ').str[0] # Remove o \"- UF\" observado nos logs\n",
        "df_ibge['cidade_limpa'] = df_ibge['cidade_limpa'].apply(limpar_texto) # Finaliza com normalização unicode\n",
        "\n",
        "# MODELAGEM SQL COM DUCKDB\n",
        "query = \"\"\"\n",
        "SELECT\n",
        "    c.cidade_limpa AS cidade,\n",
        "    c.customer_state AS uf,\n",
        "    MAX(i.populacao) AS populacao_total,\n",
        "    COUNT(DISTINCT c.customer_unique_id) AS total_clientes_unicos,\n",
        "    COUNT(o.order_id) AS total_pedidos\n",
        "FROM df_clientes c\n",
        "LEFT JOIN df_ibge i\n",
        "    ON c.cidade_limpa = i.cidade_limpa\n",
        "LEFT JOIN df_orders o\n",
        "    ON c.customer_id = o.customer_id\n",
        "GROUP BY 1, 2\n",
        "ORDER BY total_clientes_unicos DESC\n",
        "\"\"\"\n",
        "\n",
        "df_unificado = duckdb.sql(query).df()\n",
        "\n",
        "# RELATÓRIO DE QUALIDADE E LIMITAÇÕES\n",
        "print(\"Tarefa 2 Concluída: Base Unificada Gerada!\")\n",
        "\n",
        "# DISCUSSÃO TÉCNICA: Verificação de cobertura de dados (Match Rate)\n",
        "taxa_match = (df_unificado['populacao_total'].notna().sum() / len(df_unificado)) * 100\n",
        "print(f\"\\nANÁLISE DE QUALIDADE:\")\n",
        "print(f\"- Taxa de sucesso no cruzamento IBGE: {taxa_match:.2f}%\")\n",
        "print(f\"- Limitação encontrada: Valores <NA> ocorrem em cidades onde a grafia diverge entre as fontes.\")\n",
        "\n",
