        "import pandas as pd\n",
        "import requests\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import zipfile\n",
        "import os\n",
        "import unicodedata\n",
        "\n",
        "# --- 1. PREPARAÇÃO DOS ARQUIVOS ---\n",
        "# Extraindo os datasets programaticamente para garantir replicabilidade.\n",
        "for zip_file in ['olist_customers_dataset.csv.zip', 'olist_orders_dataset.csv.zip', 'archive.zip']:\n",
        "    if os.path.exists(zip_file):\n",
        "        with zipfile.ZipFile(zip_file, 'r') as zip_ref:\n",
        "            zip_ref.extractall('.')\n",
        "\n",
        "# --- 2. CARREGAMENTO DE DADOS ---\n",
        "df_clientes = pd.read_csv('olist_customers_dataset.csv')\n",
        "df_orders = pd.read_csv('olist_orders_dataset.csv')\n",
        "\n",
        "print(\"Acessando dados do IBGE (Censo 2022)...\")\n",
        "url_ibge = \"https://apisidra.ibge.gov.br/values/t/4709/n6/all/v/93/p/2022\"\n",
        "r = requests.get(url_ibge)\n",
        "df_ibge = pd.DataFrame(r.json()[1:])\n",
        "df_ibge = df_ibge[['MC', 'D1N', 'V']]\n",
        "df_ibge.columns = ['cod_mun', 'municipio', 'populacao']\n",
        "df_ibge['populacao'] = pd.to_numeric(df_ibge['populacao'], errors='coerce')\n",
        "\n",
        "print(\"Bases carregadas!\")\n",
        "\n",
        "# --- 3. LIMPEZA E PADRONIZAÇÃO (DATA PREP) ---\n",
        "def limpar_texto(txt):\n",
        "    if txt is None or pd.isna(txt):\n",
        "        return None\n",
        "    # Normalização unicode para remover acentos e padronizar para minúsculas\n",
        "    txt = unicodedata.normalize('NFKD', str(txt)).encode('ascii', 'ignore').decode('utf-8')\n",
        "    return txt.lower().strip()\n",
        "\n",
        "# Aplicação da limpeza na base Olist\n",
        "df_clientes['cidade_limpa'] = df_clientes['customer_city'].apply(limpar_texto)\n",
        "\n",
        "# SUGESTÃO APLICADA: Tratamento do sufixo de estado na base IBGE.\n",
        "# Decisão Técnica: Além do split pelo parêntese r' \\(', adicionamos o split pelo hífen ' - '.\n",
        "# Motivo: Identificamos que o IBGE traz nomes como \"Alta Floresta D'Oeste - RO\", o que impedia o match.\n",
        "df_ibge['cidade_limpa'] = df_ibge['municipio'].str.split(r' \\(').str[0] # Remove (UF)\n",
        "df_ibge['cidade_limpa'] = df_ibge['cidade_limpa'].str.split(' - ').str[0] # Remove - UF\n",
        "df_ibge['cidade_limpa'] = df_ibge['cidade_limpa'].apply(limpar_texto) # Finaliza a higienização\n",
        "\n",
        "# --- 4. VALIDAÇÃO DE DADOS (AUDITORIA) ---\n",
        "print(\"\\n=== RELATÓRIO DE CONSISTÊNCIA ===\")\n",
        "\n",
        "# Testando o cruzamento de nomes entre Olist e IBGE\n",
        "cidades_olist = set(df_clientes['cidade_limpa'].unique())\n",
        "cidades_ibge = set(df_ibge['cidade_limpa'].unique())\n",
        "match_cidades = cidades_olist.intersection(cidades_ibge)\n",
        "\n",
        "percentual_match = (len(match_cidades) / len(cidades_olist)) * 100\n",
        "\n",
        "print(f\"Cidades no Olist: {len(cidades_olist)}\")\n",
        "print(f\"Cidades encontradas no IBGE: {len(match_cidades)}\")\n",
        "print(f\"Taxa de sucesso do cruzamento (Match Rate): {percentual_match:.2f}%\")\n",
        "\n",
        "# Verificação de valores nulos na população\n",
        "nulos_pop = df_ibge['populacao'].isna().sum()\n",
        "print(f\"Registros do IBGE sem dados de população: {nulos_pop}\")\n",
        "\n",
        "# --- 5. VISUALIZAÇÃO (EDA) ---\n",
        "plt.figure(figsize=(12, 6))\n",
        "sns.countplot(\n",
        "    data=df_clientes,\n",
        "    x='customer_state',\n",
        "    hue='customer_state',\n",
        "    palette='magma',\n",
        "    legend=False,\n",
        "    order=df_clientes['customer_state'].value_counts().index\n",
        ")\n",
        "plt.title('Distribuição de Clientes por Estado (Base Olist)')\n",
        "plt.xlabel('UF')\n",
        "plt.ylabel('Total de Clientes')\n",
        "plt.show()\n",
        "\n",
        "display(df_ibge.head())"
      ]
