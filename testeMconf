      "source": [
        "# 1. Carregar base de pedidos\n",
        "df_orders = pd.read_csv('olist_orders_dataset.csv')\n",
        "\n",
        "# 2. Tratamento de datas\n",
        "df_orders['order_purchase_timestamp'] = pd.to_datetime(df_orders['order_purchase_timestamp'])\n",
        "df_orders['mes_ano'] = df_orders['order_purchase_timestamp'].dt.to_period('M').astype(str)\n",
        "\n",
        "# 3. Agrupamento mensal\n",
        "vendas_mensais = df_orders.groupby('mes_ano').size().reset_index(name='pedidos')\n",
        "\n",
        "# 4. Gráfico de Evolução Temporal\n",
        "fig_sazonalidade = px.line(\n",
        "    vendas_mensais,\n",
        "    x='mes_ano',\n",
        "    y='pedidos',\n",
        "    title='Sazonalidade: Evolução Mensal do Volume de Pedidos',\n",
        "    labels={'mes_ano': 'Mês de Referência', 'pedidos': 'Total de Pedidos'},\n",
        "    markers=True,\n",
        "    color_discrete_sequence=['#1f77b4']\n",
        ")\n",
        "fig_sazonalidade.show()"
      ],
