        "import pandas as pd\n",
        "import requests\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "import zipfile\n",
        "\n",
        "# Descompactar o arquivo zip para acessar o CSV\n",
        "# O kernel state indica que o arquivo é 'olist_customers_dataset.csv.zip'\n",
        "zip_file_path = 'olist_customers_dataset.csv.zip'\n",
        "with zipfile.ZipFile(zip_file_path, 'r') as zip_ref:\n",
        "    zip_ref.extractall('.') # Extrai para o diretório atual\n",
        "\n",
        "# 1. Lendo os dados que você extraiu\n",
        "df_clientes = pd.read_csv('olist_customers_dataset.csv')\n",
        "\n",
        "# 2. Buscando dados do IBGE via API (Censo 2022)\n",
        "print(\"Acessando dados do IBGE... Por favor, aguarde.\")\n",
        "url_ibge = \"https://apisidra.ibge.gov.br/values/t/4709/n6/all/v/93/p/2022\"\n",
        "r = requests.get(url_ibge)\n",
        "\n",
        "# O JSON retornado contém a primeira linha como cabeçalho. Ignoramos a primeira linha (cabeçalho) e criamos o DataFrame.\n",
        "# O DataFrame df_ibge terá 11 colunas com os nomes originais da API (ex: 'MC', 'D1N', 'V').\n",
        "df_ibge = pd.DataFrame(r.json()[1:])\n",
        "\n",
        "# Selecionar as colunas relevantes e renomeá-las.\n",
        "# Assumindo 'MC' como código do município, 'D1N' como nome do município e 'V' como população.\n",
        "df_ibge = df_ibge[['MC', 'D1N', 'V']]\n",
        "df_ibge.columns = ['cod_mun', 'municipio', 'populacao']\n",
        "\n",
        "df_ibge['populacao'] = pd.to_numeric(df_ibge['populacao'], errors='coerce')\n",
        "\n",
        "print(\"Sucesso! Bases carregadas.\")\n",
        "\n",
        "# 3. Gráfico de Clientes por Estado (Insight para a diretoria)\n",
        "plt.figure(figsize=(12, 6))\n",
        "sns.countplot(data=df_clientes, x='customer_state', palette='magma',\n",
        "              order=df_clientes['customer_state'].value_counts().index) # Corrigido o erro de sintaxe aqui\n",
        "plt.title('Onde estão nossos clientes hoje? (Distribuição por Estado)')\n",
        "plt.show()\n",
        "\n",
        "# Mostrando as primeiras linhas da população para o seu relatório\n",
        "print(\"\\nPrimeiras 5 cidades da base do IBGE:\")\n",
        "display(df_ibge.head())"
      ]
